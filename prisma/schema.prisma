generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── USERS ───────────────────────────────────────────────

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  name               String
  hashedPassword     String?
  image              String?
  role               String   @default("USER")
  balance            Float    @default(1000)
  apiKey             String?  @unique
  emailNotifications Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  accounts  Account[]
  sessions  Session[]
  trades    Trade[]
  positions Position[]
  comments  Comment[]
  ledger    Ledger[]
  orders    Order[]
  disputes  Dispute[]

  @@index([email])
  @@index([role])
  @@index([apiKey])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── MARKETS ─────────────────────────────────────────────

model Market {
  id             String    @id @default(cuid())
  title          String
  description    String
  category       String
  status         String    @default("OPEN")
  resolution     String?
  resolutionNote String?
  imageUrl       String?
  closesAt       DateTime
  resolvedAt     DateTime?
  createdById    String
  featured       Boolean   @default(false)
  region         String    @default("NO") // "NO" = Norway, "INT" = International
  metaTitleNo    String?                       // Norwegian title for SEO meta
  metaDescNo     String?                       // Norwegian description for SEO meta

  poolYes     Float @default(100)
  poolNo      Float @default(100)
  totalVolume Float @default(0)

  // Resolution metadata
  resolutionSources   String?   // How this market will be resolved (data sources, criteria)
  disputePeriodHours  Int       @default(24)
  disputeCount        Int       @default(0)
  pendingResolutionAt DateTime? // When admin initiated resolution

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trades         Trade[]
  positions      Position[]
  priceSnapshots PriceSnapshot[]
  comments       Comment[]
  ledger         Ledger[]
  orders         Order[]
  disputes       Dispute[]

  @@index([category])
  @@index([status])
  @@index([featured])
  @@index([closesAt])
  @@index([region])
}

// ─── TRADING ─────────────────────────────────────────────

model Trade {
  id        String   @id @default(cuid())
  userId    String
  marketId  String
  side      String
  direction String
  amount    Float
  shares    Float
  price     Float
  fee       Float    @default(0)
  createdAt DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  market      Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  ledger      Ledger[]
  filledOrder Order?

  @@index([userId])
  @@index([marketId])
  @@index([createdAt])
}

model Position {
  id       String @id @default(cuid())
  userId   String
  marketId String
  side     String
  shares   Float  @default(0)
  avgPrice Float  @default(0)
  realized Float  @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@unique([userId, marketId, side])
  @@index([userId])
  @@index([marketId])
}

// ─── PRICE HISTORY ──────────────────────────────────────

model PriceSnapshot {
  id        String   @id @default(cuid())
  marketId  String
  yesPrice  Float
  noPrice   Float
  timestamp DateTime @default(now())

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId, timestamp])
}

// ─── NEWS PIPELINE ─────────────────────────────────────

model SuggestedMarket {
  id             String   @id @default(cuid())
  title          String
  description    String
  category       String
  closesAt       DateTime
  imageUrl       String?
  sourceHeadline String
  sourceUrl      String?
  sourceName     String?
  aiReasoning    String?
  status         String   @default("PENDING") // PENDING, APPROVED, REJECTED, PUBLISHED
  reviewedAt     DateTime?
  publishedMarketId String?
  createdAt      DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

model PipelineRun {
  id            String   @id @default(cuid())
  source        String   // "newsapi", "gnews", "manual", "cron"
  articlesFound Int      @default(0)
  suggested     Int      @default(0)
  errors        String?
  duration      Int      @default(0) // milliseconds
  createdAt     DateTime @default(now())
}

// ─── WAITLIST ────────────────────────────────────────────

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String   @default("waitlist") // "waitlist", "landing", "social"
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ─── BLOG ───────────────────────────────────────────────

model BlogPost {
  id             String    @id @default(cuid())
  slug           String    @unique
  title          String                        // English title (displayed)
  excerpt        String                        // Short summary for cards
  content        String                        // Markdown body
  metaTitleNo    String?                       // Norwegian title for <title> / OG
  metaDescNo     String?                       // Norwegian description for meta
  category       String    @default("ANALYSIS") // ANALYSIS, NEWS, GUIDE
  linkedMarketId String?                       // optional link to a market
  published      Boolean   @default(false)
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([slug])
  @@index([published, publishedAt])
  @@index([category])
}

// ─── TRANSACTION LEDGER ─────────────────────────────────

model Ledger {
  id           String   @id @default(cuid())
  userId       String
  type         String   // DEPOSIT, BUY, SELL, WIN, LOSS
  amount       Float    // positive = credit, negative = debit
  balanceAfter Float
  description  String?
  marketId     String?
  tradeId      String?
  createdAt    DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  market Market? @relation(fields: [marketId], references: [id], onDelete: SetNull)
  trade  Trade?  @relation(fields: [tradeId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([marketId])
  @@index([type])
}

// ─── LIMIT ORDERS ───────────────────────────────────────

model Order {
  id          String    @id @default(cuid())
  userId      String
  marketId    String
  side        String    // YES or NO
  targetPrice Float     // price at which to execute (0.01 to 0.99)
  amount      Float     // points to spend when triggered
  status      String    @default("PENDING") // PENDING, FILLED, CANCELLED, EXPIRED
  filledAt    DateTime?
  tradeId     String?   @unique // link to Trade created when filled
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)
  trade  Trade? @relation(fields: [tradeId], references: [id])

  @@index([marketId, status])
  @@index([userId])
  @@index([status])
}

// ─── DISPUTES ───────────────────────────────────────────

model Dispute {
  id        String   @id @default(cuid())
  marketId  String
  userId    String
  reason    String
  status    String   @default("OPEN") // OPEN, DISMISSED, UPHELD
  createdAt DateTime @default(now())

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([marketId, userId])
  @@index([marketId, status])
}

// ─── COMMENTS ───────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  marketId  String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  market  Market    @relation(fields: [marketId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@index([marketId, createdAt])
}
